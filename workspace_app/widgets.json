          { "field": "bullish_pct", "headerName": "Bullish %", "cellDataType": "number", "chartDataType": "series", "formatterFn": "none", "decimalPlaces": 2, "renderFn": "greenRed", "width": 120 },
          { "field": "bearish_pct", "headerName": "Bearish %", "cellDataType": "number", "chartDataType": "series", "formatterFn": "none", "decimalPlaces": 2, "renderFn": "greenRed", "width": 120 }
